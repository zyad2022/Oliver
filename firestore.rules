rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Catch-all: Deny any unspecified access
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // PRIMITIVE DEFINITIONS
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // -------------------------------------------------------------------------
    // ENTITY BLUEPRINTS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'createdAt'])
        && data.keys().size() == 4
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalItems', 'subtotal', 'totalPrice', 'paymentMethod', 'status', 'createdAt'])
        && data.keys().size() == 8
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.totalItems is number && data.totalItems > 0
        && data.subtotal is number && data.subtotal >= 0
        && data.totalPrice is number && data.totalPrice >= 0
        && data.paymentMethod is string && data.paymentMethod.size() <= 100
        && data.status is string && data.status.size() <= 50
        && data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['name', 'comment', 'rating', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.comment is string && data.comment.size() > 0 && data.comment.size() <= 1000
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.createdAt == request.time;
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 150
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // ROUTING / MATCH BLOCKS
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow read only to the owner
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow list: if false; // Blanket lists forbidden to prevent PII leaks

      // Create: User can only create their own profile, matching their auth credentials
      allow create: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid;

      // Update: User can update their own profile (e.g., name block)
      // Here we only allow changing the 'name' field
      allow update: if isSignedIn() 
        && isValidId(userId)
        && request.auth.uid == userId
        && request.auth.uid == existing().uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['name'])
        && incoming().name is string
        && incoming().name.size() <= 100
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;

      allow delete: if false; // Do not allow manual deletion via client SDK

      match /orders/{orderId} {
        // Allow read only to the owner
        allow get: if isSignedIn() && isValidId(orderId) && request.auth.uid == userId;
        
        // Allow user to query their own orders list
        allow list: if isSignedIn() && request.auth.uid == userId;

        // Allow order creation logic
        allow create: if isSignedIn() 
          && isVerified()
          && isValidId(orderId)
          && userId == request.auth.uid
          && isValidOrder(incoming())
          && incoming().userId == request.auth.uid;

        allow update: if false; 
        allow delete: if false; 
      }
    }
    
    match /reviews/{reviewId} {
      allow read: if true; // Public can see reviews
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update: if false;
      allow delete: if false;
    }

    match /contact_messages/{messageId} {
      allow read: if false; // Only admins should read these (via console)
      allow create: if isValidId(messageId) && isValidContactMessage(incoming());
      allow update: if false;
      allow delete: if false;
    }
    
  }
}
