{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile data and basic account info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "description": "Email address of the user" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "name", "email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores user order history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "total", "status", "items", "createdAt"]
    },
    "Review": {
      "title": "Customer Review",
      "description": "Stores customer feedback and ratings.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "comment": { "type": "string" },
        "rating": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["name", "comment", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles collection, keyed by user UID."
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders collection."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Customer reviews collection."
    }
  }
}
